# Sanity CMS Configuration
# Get your project ID and dataset from https://sanity.io
# 1. Go to sanity.io and create a new project
# 2. Note your Project ID and Dataset name (usually "production")
# 3. Create an API token at manage.sanity.io > API > Tokens > Add API Token (copy the token)

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_PROJECT_ID=your_project_id_here
SANITY_API_TOKEN=your_api_token_here

# DeepL Translation API
# 1. Sign up for free at https://www.deepl.com/pro#developer
# 2. You'll get 500,000 characters/month for free
# 3. Copy your API key from the account settings
# If not provided, the app will fall back to Google Translate (lower quality)

DEEPL_API_KEY=your_deepl_api_key_here

# Optional: Google Translate API Key
# Only needed if you want to use Google Translate instead of DeepL
# Leave empty to use DeepL or the built-in fallback translator

GOOGLE_TRANSLATE_API_KEY=

# Next.js Environment
NODE_ENV=development

# Optional: Sanity API version for Sanity client
SANITY_API_VERSION=2024-08-01

# Optional: how often Next.js refreshes data from Sanity (seconds)
SANITY_REVALIDATE_SECONDS=300

