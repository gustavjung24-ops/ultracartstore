# Sanity CMS connection
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production

# Optional: only needed for private dataset or preview access
SANITY_API_TOKEN=

# Optional: API version for Sanity client
SANITY_API_VERSION=2024-08-01

# Optional: how often Next.js refreshes data from Sanity (seconds)
SANITY_REVALIDATE_SECONDS=300
